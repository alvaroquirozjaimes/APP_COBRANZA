NODE_ENV=development
PORT=5000

DB_USER=tu_usuario
DB_PASSWORD=tu_password
DB_NAME=tu_base_de_datos
DB_HOST=localhost
DB_PORT=5432
DB_SSL=false
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=10000

JWT_SECRET=coloca_un_secreto_largo_y_seguro
JWT_EXPIRES_IN=1h
BCRYPT_SALT_ROUNDS=10

# En producción, coloca aquí la URL real del frontend.
# Ejemplo: CORS_ORIGIN=https://tudominio.com
CORS_ORIGIN=*

# Mantiene la funcionalidad actual. En producción puedes poner false si no deseas registro público.
ALLOW_PUBLIC_REGISTER=true

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
WRITE_RATE_LIMIT_WINDOW_MS=900000
WRITE_RATE_LIMIT_MAX=80
